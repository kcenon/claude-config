{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Project-specific overrides only. Inherits defaults from global settings (~/.claude/settings.json).",
  "version": "1.8.0",

  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(./.npm-cache/**)",
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/markdown-anchor-validator.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'export TZ=Asia/Seoul' >> \"$CLAUDE_ENV_FILE\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
