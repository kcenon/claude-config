{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kcenon/claude-config/scripts/schemas/plugin-json.schema.json",
  "title": "Claude Code plugin.json",
  "description": "Canonical schema for Claude Code plugin manifest at .claude-plugin/plugin.json.",
  "type": "object",
  "required": ["name", "version", "description"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 128,
      "description": "Plugin identifier. Lowercase letters, digits, and hyphens; cannot start with hyphen."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version string (MAJOR.MINOR.PATCH)."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "author": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" },
            "email": { "type": "string", "format": "email" }
          }
        }
      ]
    },
    "homepage": { "type": "string", "format": "uri" },
    "repository": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "url":  { "type": "string" }
          }
        }
      ]
    },
    "license": { "type": "string", "minLength": 1 },
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "minClaudeCodeVersion": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*).*$"
        },
        "maxClaudeCodeVersion": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*).*$"
        }
      }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
